# Needle Vector Database - Environment Variables
# Copy to .env and adjust as needed

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: error, warn, info, debug, trace
# Supports per-module filtering: needle=debug,tower_http=info
RUST_LOG=info

# ── Server Mode (cargo run --features server -- serve) ────────────────────────
# Listen address and port
NEEDLE_ADDRESS=127.0.0.1:8080

# Database file path
NEEDLE_DATA_DIR=/data
NEEDLE_DATABASE=needle.db

# ── OpenTelemetry (cargo run --features server) ──────────────────────────────
# OTLP endpoint for exporting traces (e.g., Jaeger, Grafana Tempo)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Service name reported in traces
# OTEL_SERVICE_NAME=needle

# ── Embedding Providers (cargo run --features embedding-providers) ───────────
# API key for OpenAI embedding models
# OPENAI_API_KEY=sk-...
# API key for Cohere embedding/reranking models
# COHERE_API_KEY=...
# API key for Hugging Face Inference API
# HUGGINGFACE_API_KEY=hf_...
# Hugging Face model name (default: sentence-transformers/all-MiniLM-L6-v2)
# HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Experimental Platform Adapters (cargo run --features experimental) ───────
# Edge runtime configuration (e.g., Vercel Edge Config)
# EDGE_CONFIG=...
# Blob storage read/write token (e.g., Vercel Blob)
# BLOB_READ_WRITE_TOKEN=...

# ── Docker / Production ───────────────────────────────────────────────────────
# These are set automatically in the Docker image
# NEEDLE_DATA_DIR=/data
# RUST_LOG=info
