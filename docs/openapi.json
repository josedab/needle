{
  "components": {
    "schemas": {
      "CollectionInfo": {
        "properties": {
          "dimensions": {
            "type": "integer"
          },
          "distance_function": {
            "enum": [
              "cosine",
              "euclidean",
              "dot_product",
              "manhattan"
            ],
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "vector_count": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "CreateCollectionRequest": {
        "properties": {
          "dimensions": {
            "minimum": 1,
            "type": "integer"
          },
          "distance": {
            "default": "cosine",
            "enum": [
              "cosine",
              "euclidean",
              "dot_product",
              "manhattan"
            ],
            "type": "string"
          },
          "ef_construction": {
            "default": 200,
            "type": "integer"
          },
          "m": {
            "default": 16,
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "dimensions"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "example": "healthy",
            "type": "string"
          }
        },
        "type": "object"
      },
      "InsertVectorRequest": {
        "properties": {
          "id": {
            "type": "string"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object"
          },
          "vector": {
            "items": {
              "format": "float",
              "type": "number"
            },
            "type": "array"
          }
        },
        "required": [
          "id",
          "vector"
        ],
        "type": "object"
      },
      "SearchRequest": {
        "properties": {
          "ef_search": {
            "type": "integer"
          },
          "filter": {
            "description": "MongoDB-style metadata filter",
            "type": "object"
          },
          "k": {
            "default": 10,
            "minimum": 1,
            "type": "integer"
          },
          "vector": {
            "items": {
              "format": "float",
              "type": "number"
            },
            "type": "array"
          }
        },
        "required": [
          "vector"
        ],
        "type": "object"
      },
      "SearchResponse": {
        "properties": {
          "results": {
            "items": {
              "properties": {
                "distance": {
                  "type": "number"
                },
                "id": {
                  "type": "string"
                },
                "metadata": {
                  "nullable": true,
                  "type": "object"
                }
              },
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "VectorResponse": {
        "properties": {
          "id": {
            "type": "string"
          },
          "metadata": {
            "nullable": true,
            "type": "object"
          },
          "vector": {
            "items": {
              "type": "number"
            },
            "type": "array"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "in": "header",
        "name": "X-API-Key",
        "type": "apiKey"
      },
      "BearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Needle Team"
    },
    "description": "REST API for the Needle embedded vector database",
    "license": {
      "name": "MIT"
    },
    "title": "Needle Vector Database API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/collections": {
      "get": {
        "operationId": "listCollections",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CollectionInfo"
                  },
                  "type": "array"
                }
              }
            },
            "description": "List of collections"
          }
        },
        "summary": "List all collections",
        "tags": [
          "Collections"
        ]
      },
      "post": {
        "operationId": "createCollection",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCollectionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Collection created"
          },
          "409": {
            "description": "Collection already exists"
          }
        },
        "summary": "Create a new collection",
        "tags": [
          "Collections"
        ]
      }
    },
    "/collections/{collection}/search": {
      "post": {
        "operationId": "searchVectors",
        "parameters": [
          {
            "in": "path",
            "name": "collection",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            },
            "description": "Search results"
          }
        },
        "summary": "Search for similar vectors",
        "tags": [
          "Search"
        ]
      }
    },
    "/collections/{collection}/vectors": {
      "get": {
        "operationId": "listVectors",
        "parameters": [
          {
            "in": "path",
            "name": "collection",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 100,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "default": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of vectors"
          }
        },
        "summary": "List vectors in collection",
        "tags": [
          "Vectors"
        ]
      },
      "post": {
        "operationId": "insertVector",
        "parameters": [
          {
            "in": "path",
            "name": "collection",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InsertVectorRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Vector inserted"
          },
          "400": {
            "description": "Invalid input"
          }
        },
        "summary": "Insert a vector",
        "tags": [
          "Vectors"
        ]
      }
    },
    "/collections/{collection}/vectors/{id}": {
      "delete": {
        "operationId": "deleteVector",
        "parameters": [
          {
            "in": "path",
            "name": "collection",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vector deleted"
          },
          "404": {
            "description": "Not found"
          }
        },
        "summary": "Delete a vector",
        "tags": [
          "Vectors"
        ]
      },
      "get": {
        "operationId": "getVector",
        "parameters": [
          {
            "in": "path",
            "name": "collection",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VectorResponse"
                }
              }
            },
            "description": "Vector data"
          },
          "404": {
            "description": "Vector not found"
          }
        },
        "summary": "Get a vector by ID",
        "tags": [
          "Vectors"
        ]
      }
    },
    "/collections/{name}": {
      "delete": {
        "operationId": "deleteCollection",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection deleted"
          },
          "404": {
            "description": "Collection not found"
          }
        },
        "summary": "Delete a collection",
        "tags": [
          "Collections"
        ]
      },
      "get": {
        "operationId": "getCollection",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionInfo"
                }
              }
            },
            "description": "Collection info"
          },
          "404": {
            "description": "Collection not found"
          }
        },
        "summary": "Get collection info",
        "tags": [
          "Collections"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Server is healthy"
          }
        },
        "summary": "Health check",
        "tags": [
          "System"
        ]
      }
    },
    "/save": {
      "post": {
        "operationId": "saveDatabase",
        "responses": {
          "200": {
            "description": "Database saved"
          }
        },
        "summary": "Save database to disk",
        "tags": [
          "System"
        ]
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    },
    {
      "BearerAuth": []
    }
  ],
  "servers": [
    {
      "description": "Local development",
      "url": "http://localhost:8080"
    }
  ]
}